{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "run-summary.schema.json",
  "title": "run-summary.json",
  "description": "Lightweight audit summary retained after succeed/abort/fail. Must not contain detailed logs, prompts, diffs, tokens, or environment variables.",
  "type": "object",
  "required": [
    "schema_version",
    "repository",
    "issue_number",
    "run_id",
    "branch",
    "worktree",
    "terminal_state",
    "completion_result",
    "started_at",
    "finished_at",
    "review_rounds",
    "minor_findings",
    "forced"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "repository": {
      "type": "string",
      "pattern": "^[^/]+/[^/]+$"
    },
    "issue_number": {
      "type": "integer",
      "minimum": 1
    },
    "run_id": {
      "type": "string",
      "format": "uuid"
    },
    "branch": {
      "type": "string",
      "minLength": 1
    },
    "worktree": {
      "type": "string",
      "minLength": 1
    },
    "pull_request": {
      "type": "object",
      "required": ["number", "url"],
      "additionalProperties": false,
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "terminal_state": {
      "type": "string",
      "enum": ["succeeded", "aborted", "failed"]
    },
    "completion_result": {
      "type": "string",
      "enum": [
        "pr_created",
        "no_pr_created",
        "aborted_by_user",
        "failed_due_to_invalid_state",
        "failed_due_to_agent_error",
        "failed_due_to_git_error",
        "failed_due_to_github_error",
        "failed_due_to_verification_error",
        "failed_due_to_runner_error",
        "failed_due_to_environment_error"
      ]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "review_rounds": {
      "type": "integer",
      "minimum": 0
    },
    "minor_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "message"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "category": {
            "type": "string",
            "enum": [
              "bug", "test", "scope", "design",
              "security", "docs", "style", "maintainability", "other"
            ]
          },
          "message": { "type": "string" }
        }
      }
    },
    "forced": {
      "type": "boolean"
    },
    "failure_summary": {
      "type": "object",
      "required": ["code", "phase", "message", "recoverability", "occurred_at"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "github_auth_failed",
            "issue_not_found",
            "issue_closed",
            "main_update_failed",
            "worktree_create_failed",
            "branch_already_exists",
            "worktree_path_already_exists",
            "writer_launch_failed",
            "invalid_writer_output",
            "verification_failed",
            "nothing_to_commit",
            "commit_failed",
            "reviewer_launch_failed",
            "invalid_reviewer_output",
            "push_failed",
            "pr_create_failed",
            "runner_error",
            "environment_error"
          ]
        },
        "phase": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "recoverability": {
          "type": "string",
          "enum": [
            "retryable",
            "retryable_after_human_confirmation",
            "retryable_after_manual_fix",
            "manual_inspection_required",
            "terminal"
          ]
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "artifact_ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*(^|/)\\.\\./|/\\.\\.$|\\.\\.$).+$"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "completion_result": { "const": "pr_created" } },
        "required": ["completion_result"]
      },
      "then": {
        "required": ["pull_request"]
      },
      "else": {
        "not": { "required": ["pull_request"] }
      }
    },
    {
      "if": {
        "properties": { "terminal_state": { "const": "failed" } },
        "required": ["terminal_state"]
      },
      "then": {
        "required": ["failure_summary"]
      },
      "else": {
        "not": { "required": ["failure_summary"] }
      }
    }
  ]
}
