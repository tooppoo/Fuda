{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "review.schema.json",
  "title": "review-N.json",
  "description": "Normalized reviewer output for the N-th review round. Not the raw reviewer output.",
  "type": "object",
  "required": [
    "schema_version",
    "review_number",
    "reviewer_assessment",
    "findings",
    "human_review_required",
    "runner_decision"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "review_number": {
      "type": "integer",
      "minimum": 1
    },
    "reviewer_assessment": {
      "type": "string",
      "enum": ["pass", "needs_fix"]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "category", "message", "required_fix"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["blocking", "major", "minor"]
          },
          "category": {
            "type": "string",
            "enum": [
              "bug", "test", "scope", "design",
              "security", "docs", "style", "maintainability", "other"
            ]
          },
          "message": { "type": "string" },
          "required_fix": { "type": "string" },
          "file": { "type": "string" },
          "line": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "human_review_required": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "reason", "question", "blocking", "related_finding_ids"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "reason": { "type": "string" },
          "question": { "type": "string" },
          "blocking": { "type": "boolean" },
          "related_finding_ids": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "runner_decision": {
      "type": "string",
      "enum": [
        "pass",
        "ready_with_minor_findings",
        "needs_revision",
        "human_review_required"
      ]
    }
  }
}
